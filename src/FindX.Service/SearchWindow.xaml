<Window x:Class="FindX.Service.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FindX" Width="960" Height="620"
        Icon="findx-icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <!-- Segoe Fluent Icons font -->
        <FontFamily x:Key="SymbolFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
        <DropShadowEffect x:Key="PopupShadow" ShadowDepth="2" BlurRadius="8" Opacity="0.2"/>

        <!-- Sidebar filter button style -->
        <Style x:Key="FilterBtn" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="12,7" CornerRadius="6"
                                Background="Transparent" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}"
                                           FontFamily="{StaticResource SymbolFont}" FontSize="14"
                                           VerticalAlignment="Center" Width="22"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DCEEFB"/>
                                <Setter Property="Foreground" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="GroupName" Value="TypeFilter"/>
        </Style>

        <!-- Time filter radio style -->
        <Style x:Key="TimeRadio" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="12,5" CornerRadius="4"
                                Background="Transparent" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Dot" Width="8" Height="8"
                                         Stroke="#999" StrokeThickness="1.2"
                                         Fill="Transparent" Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="12.5"
                                           Foreground="#555" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Fill" Value="#0078D4"/>
                                <Setter TargetName="Dot" Property="Stroke" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="GroupName" Value="TimeFilter"/>
        </Style>

        <!-- Result row hover style -->
        <Style x:Key="ResultItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="0,2">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Search Bar ═══ -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="12,0">
                        <Grid>
                            <TextBlock x:Name="SearchPlaceholder" Text="搜索文件和文件夹..."
                                       Foreground="#AAA" FontSize="15"
                                       VerticalAlignment="Center" Margin="4,0,0,0"
                                       IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox" FontSize="15" Background="Transparent"
                                     BorderThickness="0" Padding="4,8"
                                     VerticalContentAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"
                                     KeyDown="SearchBox_KeyDown"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="&#xE81C;" FontFamily="{StaticResource SymbolFont}"
                                FontSize="14" Margin="6,0,0,0" Padding="10,8"
                                Background="Transparent" Foreground="#888"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="搜索历史"
                                Click="HistoryBtn_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="&#xE721;" FontFamily="{StaticResource SymbolFont}"
                                FontSize="16" Margin="4,0,0,0" Padding="12,8"
                                Background="#0078D4" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="SearchBtn_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
                <!-- Search history popup -->
                <Popup x:Name="HistoryPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=SearchBox}"
                       StaysOpen="False" AllowsTransparency="True">
                    <Border Background="White" BorderBrush="#D0D0D0" BorderThickness="1"
                            CornerRadius="6" Padding="0" MinWidth="400"
                            Effect="{StaticResource PopupShadow}">
                        <ListBox x:Name="HistoryList" BorderThickness="0" Background="Transparent"
                                 MaxHeight="260" FontSize="13"
                                 SelectionChanged="HistoryList_SelectionChanged"/>
                    </Border>
                </Popup>
                <!-- Search progress bar -->
                <ProgressBar x:Name="SearchProgress" Grid.Row="1" Height="2" Margin="0,6,0,0"
                             IsIndeterminate="True" Visibility="Collapsed"
                             Foreground="#0078D4" Background="Transparent" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- ═══ Content Area ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── Left Sidebar ─── -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          Background="White" Padding="8,8">
                <StackPanel>
                    <TextBlock Text="筛选" FontSize="12" Foreground="#999"
                               Margin="12,4,0,10" FontWeight="SemiBold"/>

                    <RadioButton Style="{StaticResource FilterBtn}" Content="全部"
                                 Tag="&#xE71D;" IsChecked="True"
                                 Checked="TypeFilter_Changed" x:Name="FilterAll"/>
                    <RadioButton Style="{StaticResource FilterBtn}" Content="文件夹"
                                 Tag="&#xE8B7;"
                                 Checked="TypeFilter_Changed" x:Name="FilterFolder"/>
                    <RadioButton Style="{StaticResource FilterBtn}" Content="文件"
                                 Tag="&#xE7C3;"
                                 Checked="TypeFilter_Changed" x:Name="FilterFile"/>
                    <RadioButton Style="{StaticResource FilterBtn}" Content="文档"
                                 Tag="&#xE8A5;"
                                 Checked="TypeFilter_Changed" x:Name="FilterDoc"/>
                    <RadioButton Style="{StaticResource FilterBtn}" Content="图片"
                                 Tag="&#xEB9F;"
                                 Checked="TypeFilter_Changed" x:Name="FilterImage"/>
                    <RadioButton Style="{StaticResource FilterBtn}" Content="视频"
                                 Tag="&#xE714;"
                                 Checked="TypeFilter_Changed" x:Name="FilterVideo"/>
                    <RadioButton Style="{StaticResource FilterBtn}" Content="音频"
                                 Tag="&#xE8D6;"
                                 Checked="TypeFilter_Changed" x:Name="FilterAudio"/>

                    <Separator Margin="12,10" Background="#E8E8E8"/>

                    <TextBlock Text="最近修改" FontSize="12" Foreground="#999"
                               Margin="12,2,0,8" FontWeight="SemiBold"/>

                    <RadioButton Style="{StaticResource TimeRadio}" Content="全部"
                                 IsChecked="True"
                                 Checked="TimeFilter_Changed" x:Name="TimeAll"/>
                    <RadioButton Style="{StaticResource TimeRadio}" Content="最近 1 天"
                                 Checked="TimeFilter_Changed" x:Name="Time1D"/>
                    <RadioButton Style="{StaticResource TimeRadio}" Content="最近 7 天"
                                 Checked="TimeFilter_Changed" x:Name="Time7D"/>
                    <RadioButton Style="{StaticResource TimeRadio}" Content="最近 30 天"
                                 Checked="TimeFilter_Changed" x:Name="Time30D"/>
                    <RadioButton Style="{StaticResource TimeRadio}" Content="最近 365 天"
                                 Checked="TimeFilter_Changed" x:Name="Time365D"/>

                    <Separator Margin="12,10" Background="#E8E8E8"/>

                    <TextBlock Text="路径" FontSize="12" Foreground="#999"
                               Margin="12,2,0,6" FontWeight="SemiBold"/>
                    <TextBox x:Name="PathFilterBox" FontSize="12" Margin="8,0,8,0"
                             Padding="6,4" BorderBrush="#D0D0D0" BorderThickness="1"
                             ToolTip="输入路径前缀，如 C:\Users\name\dev；与上方搜索词组合过滤，留空则不限制路径"
                             Background="#FBFBFB"
                             TextChanged="SidebarFilter_TextChanged"
                             KeyDown="SidebarFilter_KeyDown"/>

                    <Separator Margin="12,10" Background="#E8E8E8"/>

                    <TextBlock Text="大小" FontSize="12" Foreground="#999"
                               Margin="12,2,0,6" FontWeight="SemiBold"/>
                    <Grid Margin="8,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SizeMinBox" Grid.Column="0" FontSize="12"
                                 Padding="4,4" BorderBrush="#D0D0D0" BorderThickness="1"
                                 ToolTip="最小 (MB)" Background="#FBFBFB"
                                 TextChanged="SidebarFilter_TextChanged"
                                 KeyDown="SidebarFilter_KeyDown"/>
                        <TextBlock Grid.Column="1" Text="~" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" Foreground="#999" FontSize="12"/>
                        <TextBox x:Name="SizeMaxBox" Grid.Column="2" FontSize="12"
                                 Padding="4,4" BorderBrush="#D0D0D0" BorderThickness="1"
                                 ToolTip="最大 (MB)" Background="#FBFBFB"
                                 TextChanged="SidebarFilter_TextChanged"
                                 KeyDown="SidebarFilter_KeyDown"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Separator -->
            <Rectangle Grid.Column="1" Fill="#E8E8E8"/>

            <!-- ─── Results List ─── -->
            <ListView Grid.Column="2" x:Name="ResultsList"
                      BorderThickness="0" Background="Transparent"
                      ItemContainerStyle="{StaticResource ResultItem}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      MouseDoubleClick="ResultsList_DoubleClick">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="打开文件" FontSize="13" Click="Ctx_Open"/>
                        <MenuItem Header="打开所在文件夹" FontSize="13" Click="Ctx_OpenFolder"/>
                        <Separator/>
                        <MenuItem Header="复制完整路径" FontSize="13" Click="Ctx_CopyPath"/>
                        <MenuItem Header="复制文件名" FontSize="13" Click="Ctx_CopyName"/>
                        <Separator/>
                        <MenuItem Header="复制为路径列表" FontSize="13" Click="Ctx_CopyAllPaths"/>
                        <Separator/>
                        <MenuItem Header="导出为 CSV" FontSize="13" Click="Ctx_ExportCsv"/>
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#FAFAFA"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <EventSetter Event="Click" Handler="ColumnHeader_Click"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="名称" Width="260">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,4">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="{StaticResource SymbolFont}"
                                                   FontSize="16" Width="24"
                                                   Foreground="{Binding IconColor}"
                                                   VerticalAlignment="Center"/>
                                        <ItemsControl ItemsSource="{Binding NameParts}"
                                                      VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="13" Text="{Binding Text}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#222"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsHighlight}" Value="True">
                                                                        <Setter Property="Background" Value="#FFECB3"/>
                                                                        <Setter Property="Foreground" Value="#0D47A1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="路径" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path}" FontSize="12"
                                               Foreground="#888" Margin="4,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FullPath}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="大小" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeText}" FontSize="12"
                                               Foreground="#888" Margin="4,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="修改时间" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ModifiedText}" FontSize="12"
                                               Foreground="#888" Margin="4,0"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="16,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" Text="就绪" FontSize="12"
                           Foreground="#888" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="IndexStatus" FontSize="12" Foreground="#888"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Content="&#xE713;" FontFamily="{StaticResource SymbolFont}"
                            FontSize="13" Padding="4,2" MinWidth="26" MinHeight="24"
                            Background="Transparent" Foreground="#888"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip="设置"
                            Click="SettingsBtn_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
